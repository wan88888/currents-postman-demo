{
  "name": "currents-postman-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test:postman": "newman run ./collection.json -r cli,junit --reporter-junit-export ./results.xml",
    "test:currents:convert": "currents convert --input-format=junit --input-file=./results.xml --framework=postman",
    "test:currents:upload": "currents upload --key=${CURRENTS_RECORD_KEY} --project-id=gnRUTN",
    "test:currents": "npm run test:postman && npm run test:currents:convert && npm run test:currents:upload"
  },
  "devDependencies": {
    "@currents/cmd": "^1.9.5",
    "newman": "^6.2.2"
  }
}
